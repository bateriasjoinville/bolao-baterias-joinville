NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Mesmo valor do dashboard Supabase > Project Settings > API > JWT Secret.
# Usado pra assinar o JWT custom (HS256) lido pelas policies RLS.
SUPABASE_JWT_SECRET=
# Criptografa o cookie bolao_session (iron-session). Mínimo 32 chars.
# Gerar: openssl rand -base64 32  ou  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=

NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Dev override: libera palpites antes da data oficial de abertura (TBD).
# Deixar vazio em produção. Em local, usar "true" pra testar /palpitar.
NEXT_PUBLIC_PALPITES_FORCE_OPEN=

ADMIN_TOKEN=

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contato@bateriasjoinville.com.br